{
  "name": "snipeit-auth-gateway",
  "version": "1.0.0",
  "description": "Secure auth gateway between frontend and Snipe-IT API",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "check": "node --check backend/server.js && node --check backend/routes.js && node --check backend/middleware.js && node --check frontend/app.js",
    "cordova:prepare": "cordova prepare",
    "cordova:android:add": "cordova platform add android",
    "cordova:android:build": "cordova build android"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^15.0.0",
    "cordova-plugin-inappbrowser": "^6.0.0"
  },
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-inappbrowser": {}
    }
  }
}
