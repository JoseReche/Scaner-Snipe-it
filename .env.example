# Porta HTTP local
PORT=3000

# URL base da API do Snipe-IT (com /api/v1 no final)
SNIPE_URL=https://seu-snipe.exemplo/api/v1

# Campo customizado usado para PA no Snipe-IT
SNIPE_PA_FIELD_KEY=_snipeit_pa_6

# Chave secreta do JWT (use valor longo e aleatório)
JWT_SECRET=troque-esta-chave-por-um-segredo-bem-longo
JWT_EXPIRES_IN=3h

# Chave mestra para criptografia das API keys (mínimo 16 chars; recomendado 32+)
ENCRYPTION_KEY=troque-por-chave-grande-e-aleatoria

# Proteções de autenticação
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_TRACK_MAX_USERS=5000
LOGIN_RATE_LIMIT_MAX=10

# Lista de origens liberadas no CORS (separadas por vírgula)
# Exemplo: CORS_ALLOWED_ORIGINS=https://scanner.empresa.com,https://intranet.empresa.com
CORS_ALLOWED_ORIGINS=
